local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local LocalPlayer = Players.LocalPlayer

local Gui = Instance.new("ScreenGui")
Gui.Name = "omamilch_V5_Final"
Gui.ResetOnSpawn = false
Gui.Parent = LocalPlayer:WaitForChild("PlayerGui")

local function applyStars(parent)
    local starContainer = Instance.new("Frame")
    starContainer.Size = UDim2.new(1, 0, 1, 0)
    starContainer.BackgroundTransparency = 1
    starContainer.ClipsDescendants = true
    starContainer.ZIndex = 1
    starContainer.Parent = parent

    task.spawn(function()
        while task.wait(0.2) do
            if parent.Visible then
                local star = Instance.new("TextLabel")
                star.BackgroundTransparency = 1
                star.Text = "★"
                star.TextColor3 = Color3.fromRGB(255, 0, 0)
                star.TextSize = math.random(12, 18)
                star.Position = UDim2.new(math.random(), 0, -0.1, 0)
                star.Parent = starContainer
                local speed = math.random(2, 4)
                task.spawn(function()
                    local conn
                    conn = RunService.RenderStepped:Connect(function(dt)
                        if not star or not star.Parent then conn:Disconnect() return end
                        star.Position = star.Position + UDim2.new(0, 0, dt * speed * 0.4, 0)
                        if star.Position.Y.Scale > 1.1 then star:Destroy() conn:Disconnect() end
                    end)
                end)
            end
        end
    end)
end

