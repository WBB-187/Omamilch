local TabHolder = Instance.new("Frame")
TabHolder.Size = UDim2.new(1, -40, 0, 100)
TabHolder.Position = UDim2.new(0, 30, 0, 80)
TabHolder.BackgroundTransparency = 1
TabHolder.Parent = MainFrame

local TabGrid = Instance.new("UIGridLayout")
TabGrid.CellSize = UDim2.new(0, 160, 0, 40)
TabGrid.CellPadding = UDim2.new(0, 10, 0, 10)
TabGrid.Parent = TabHolder

local Pages = {}
local CurrentPage = nil

local function createTab(name)
    local btn = Instance.new("TextButton")
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    btn.Text = name
    btn.TextSize = 16
    btn.TextColor3 = Color3.new(1,1,1)
    btn.Parent = TabHolder
    Instance.new("UICorner", btn)

    local page = Instance.new("ScrollingFrame")
    page.Size = UDim2.new(1, -60, 1, -220)
    page.Position = UDim2.new(0, 40, 0, 200)
    page.BackgroundTransparency = 1
    page.Visible = false
    page.CanvasSize = UDim2.new(0,0,2,0)
    page.Parent = MainFrame
    local pg = Instance.new("UIGridLayout", page)
    pg.CellSize = UDim2.new(0.48, 0, 0, 60)
    pg.CellPadding = UDim2.new(0.02, 0, 0, 15)
    
    Pages[name] = page

    btn.MouseButton1Click:Connect(function()
        if CurrentPage then CurrentPage.Visible = false end
        page.Visible = true
        CurrentPage = page
        for _,v in pairs(TabHolder:GetChildren()) do if v:IsA("TextButton") then v.BackgroundColor3 = Color3.fromRGB(30,30,30) end end
        btn.BackgroundColor3 = Color3.fromRGB(140, 80, 255)
    end)
    return page
end

local function addFeature(page, name, callback)
    local f = Instance.new("Frame")
    f.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    f.Parent = page
    Instance.new("UICorner", f)
    
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(1, 0, 1, 0)
    b.BackgroundTransparency = 1
    b.Text = "  " .. name
    b.TextSize = 18
    b.TextXAlignment = Enum.TextXAlignment.Left
    b.TextColor3 = Color3.new(1,1,1)
    b.Parent = f
    
    local active = false
    b.MouseButton1Click:Connect(function()
        active = not active
        f.BackgroundColor3 = active and Color3.fromRGB(140, 80, 255) or Color3.fromRGB(25, 25, 25)
        callback(active)
    end)
end

local pAimbot = createTab("Aimbot")
local pVisuals = createTab("Visuals")
local pVehicle = createTab("Vehicle")
local pMisc = createTab("Misc")
local pTele = createTab("Teleports")
local pAuto = createTab("AutoFarm")

addFeature(pAimbot, "Silent Aim", function() end)
addFeature(pAimbot, "FOV Circle", function() end)
addFeature(pVisuals, "ESP Names", function() end)
addFeature(pVisuals, "ESP Boxes", function() end)
addFeature(pVehicle, "Car Fly", function() end)
addFeature(pVehicle, "Speed Hack", function() end)
addFeature(pMisc, "Infinite Ammo", function() end)
addFeature(pMisc, "No Recoil", function() end)
addFeature(pTele, "Police Dept", function() end)
addFeature(pTele, "Hospital", function() end)

applyStars(MainFrame)

task.spawn(function()
    LoadBarFill:TweenSize(UDim2.new(1, 0, 1, 0), "Out", "Linear", 3)
    task.wait(3.2)
    LoadingFrame.Visible = false
    KeyFrame.Visible = true
end)

LoginBtn.MouseButton1Click:Connect(function()
    if KeyInput.Text == "omamilch V5" then
        KeyFrame.Visible = false
        MainFrame.Visible = true
        CurrentPage = Pages["Aimbot"]
        CurrentPage.Visible = true
    else
        KeyInput.Text = "WRONG KEY"
        task.wait(1)
        KeyInput.Text = ""
    end
end)

UserInputService.InputBegan:Connect(function(i, p)
    if not p and i.KeyCode == Enum.KeyCode.F3 then
        if MainFrame.Parent then MainFrame.Visible = not MainFrame.Visible end
    end
end)

local function drag(f)
    local d, i, s, p
    f.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            d = true s = input.Position p = f.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if d and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local del = input.Position - s
            f.Position = UDim2.new(p.X.Scale, p.X.Offset + del.X, p.Y.Scale, p.Y.Offset + del.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function() d = false end)
end
drag(MainFrame) drag(KeyFrame) drag(LoadingFrame)
