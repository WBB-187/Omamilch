-- omamilch V5: Final Admin & Voice Force
local player = game.Players.LocalPlayer
local userInput = game:GetService("UserInputService")
local runService = game:GetService("RunService")
local TextChatService = game:GetService("TextChatService")
local VoiceChatService = game:GetService("VoiceChatService")
local starterGui = game:GetService("StarterGui")

-- Design
local theme = {
    bg = Color3.fromRGB(0, 0, 0),
    border = Color3.fromRGB(150, 0, 255),
    stars = Color3.fromRGB(255, 0, 0)
}

local screenGui = Instance.new("ScreenGui", game.CoreGui)
screenGui.Name = "omamilchV5"

-- [OWNER] Chat Tag
if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
    TextChatService.OnIncomingMessage = function(message)
        local props = Instance.new("TextChatMessageProperties")
        if message.TextSource and message.TextSource.UserId == player.UserId then
            props.PrefixText = "<font color='#FF0000'><b>[OWNER]</b></font> " .. message.PrefixText
        end
        return props
    end
end

-- GUI Erstellung
local function createFrame(name, size, pos)
    local f = Instance.new("Frame", screenGui)
    f.Name = name
    f.Size = size
    f.Position = pos
    f.BackgroundColor3 = theme.bg
    f.BackgroundTransparency = 0.2
    f.BorderSizePixel = 2
    f.BorderColor3 = theme.border
    f.Active = true
    f.Draggable = true
    return f
end

local main = createFrame("Main", UDim2.new(0, 220, 0, 350), UDim2.new(0.5, -110, 0.5, -175))
local container = Instance.new("ScrollingFrame", main)
container.Size = UDim2.new(1, -10, 0.85, 0)
container.Position = UDim2.new(0, 5, 0.12, 0)
container.BackgroundTransparency = 1
Instance.new("UIListLayout", container).Padding = UDim.new(0, 5)

-- VOICE FORCE / ANTI MUTE (Versucht Voice permanent aktiv zu halten)
local function forceVoice()
    task.spawn(function()
        while true do
            pcall(function()
                if not VoiceChatService:IsVoiceChatEnabledForUserIdAsync(player.UserId) then
                    -- Versucht den Service neu zu triggern
                    VoiceChatService:joinVoice()
                end
            end)
            task.wait(10) -- Prüft alle 10 Sekunden
        end
    end)
end

-- FLY SYSTEM (Präzise Steuerung: Stoppt bei Stillstand)
local flying = false
local flySpeed = 80
local bv, bg

local function toggleFly()
    flying = not flying
    local root = player.Character:WaitForChild("HumanoidRootPart")
    if flying then
        bv = Instance.new("BodyVelocity", root)
        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bg = Instance.new("BodyGyro", root)
        bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        bg.P = 30000

        task.spawn(function()
            while flying do
                local cam = workspace.CurrentCamera.CFrame
                local dir = Vector3.new(0,0.05,0) -- Minimaler Auftrieb gegen Schwerkraft
                
                if userInput:IsKeyDown(Enum.KeyCode.W) then dir = cam.LookVector
                elseif userInput:IsKeyDown(Enum.KeyCode.S) then dir = -cam.LookVector
                elseif userInput:IsKeyDown(Enum.KeyCode.A) then dir = -cam.RightVector
                elseif userInput:IsKeyDown(Enum.KeyCode.D) then dir = cam.RightVector
                end
                
                if dir.Magnitude > 0.1 then
                    bv.Velocity = dir * flySpeed
                else
                    bv.Velocity = Vector3.new(0,0,0) -- Sofortiger Stopp
                end
                bg.CFrame = cam
                task.wait()
            end
            bv:Destroy() bg:Destroy()
        end)
    end
end

-- EMOTE FIX (Direktes Laden über Humanoid)
local function playEmote(id)
    local char = player.Character
    if char and char:FindFirstChild("Humanoid") then
        local anim = Instance.new("Animation")
        anim.AnimationId = "rbxassetid://" .. id
        local track = char.Humanoid:LoadAnimation(anim)
        track:Play()
        if id == "148840339" then track:AdjustSpeed(4) end
    end
end

-- BUTTONS
local function btn(t, f)
    local b = Instance.new("TextButton", container)
    b.Size = UDim2.new(1, 0, 0, 35)
    b.Text = t
    b.BackgroundColor3 = Color3.fromRGB(30,30,30)
    b.TextColor3 = Color3.new(1,1,1)
    b.MouseButton1Click:Connect(f)
end

btn("Fly (Fixed WASD/Stop)", toggleFly)
btn("Emote: Bang", function() playEmote("148840339") end)
btn("Emote: Suck", function() playEmote("204328711") end)
btn("Force Voice Active", function() 
    forceVoice() 
    starterGui:SetCore("ChatMakeSystemMessage", {Text = "[SYSTEM] Voice-Anti-Ban aktiviert.", Color = Color3.new(0,1,0)})
end)
btn("Deep Admin List", function() screenGui.AdminMenu.Visible = not screenGui.AdminMenu.Visible end)

-- PC F3 Toggle
userInput.InputBegan:Connect(function(i, g)
    if not g and i.KeyCode == Enum.KeyCode.F3 then main.Visible = not main.Visible end
end)

