local title = Instance.new("TextLabel", main)
title.Size = UDim2.new(1, 0, 0, 30)
title.BackgroundColor3 = theme.border
title.Text = "[OWNER] V5"
title.TextColor3 = Color3.new(1,1,1)
title.Font = Enum.Font.SourceSansBold

local container = Instance.new("ScrollingFrame", main)
container.Size = UDim2.new(1, -6, 0.85, 0)
container.Position = UDim2.new(0, 3, 0.12, 0)
container.BackgroundTransparency = 1
container.ScrollBarThickness = 2
Instance.new("UIListLayout", container).Padding = UDim.new(0, 3)

-- PLAYER LIST (KOMPAKT)
local pFrame = createFrame("PlayerList", UDim2.new(0, 200, 0, 300), UDim2.new(0.5, -100, 0.5, -150))
pFrame.Visible = false

local pTitle = Instance.new("TextLabel", pFrame)
pTitle.Size = UDim2.new(1, 0, 0, 30)
pTitle.Text = "TARGET SELECTOR"
pTitle.BackgroundColor3 = Color3.fromRGB(50, 0, 0)
pTitle.TextColor3 = Color3.new(1,1,1)

local pList = Instance.new("ScrollingFrame", pFrame)
pList.Size = UDim2.new(1, -6, 0.88, 0)
pList.Position = UDim2.new(0, 3, 0.12, 0)
pList.BackgroundTransparency = 1
pList.ScrollBarThickness = 2
Instance.new("UIListLayout", pList)

-- --- FUNKTIONEN ---

local flying = false
local flySpeed = 80
local bv, bg

local function toggleFly()
    flying = not flying
    local root = player.Character.HumanoidRootPart
    if flying then
        bv = Instance.new("BodyVelocity", root)
        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bg = Instance.new("BodyGyro", root)
        bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        bg.P = 30000
        task.spawn(function()
            while flying do
                local cam = workspace.CurrentCamera.CFrame
                local dir = Vector3.new(0, 0.05, 0)
                if userInput:IsKeyDown(Enum.KeyCode.W) then dir = cam.LookVector
                elseif userInput:IsKeyDown(Enum.KeyCode.S) then dir = -cam.LookVector end
                bv.Velocity = (dir.Magnitude > 0.1) and (dir * flySpeed) or Vector3.new(0,0,0)
                bg.CFrame = cam
                task.wait()
            end
            bv:Destroy() bg:Destroy()
        end)
    end
end

-- Visueller Kick/Ban
local function deepAdmin(target, action)
    if target and target.Character then
        target.Character:Destroy()
        target:Destroy()
        starterGui:SetCore("ChatMakeSystemMessage", {
            Text = "[SERVER] Spieler " .. target.Name .. " wurde " .. action .. "iert.",
            Color = Color3.new(1,0,0)
        })
    end
end

local function updateList()
    for _, v in pairs(pList:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= player then
            local row = Instance.new("Frame", pList)
            row.Size = UDim2.new(1, 0, 0, 60) -- Höher für Buttons
            row.BackgroundTransparency = 0.8
            row.BackgroundColor3 = Color3.new(0.2,0.2,0.2)

            local name = Instance.new("TextLabel", row)
            name.Size = UDim2.new(1, 0, 0, 20)
            name.Text = p.DisplayName
            name.TextColor3 = Color3.new(1,1,1)
            name.TextScaled = true

            -- TP Button
            local tp = Instance.new("TextButton", row)
            tp.Size = UDim2.new(0.3, 0, 0, 30)
            tp.Position = UDim2.new(0, 0, 0.4, 0)
            tp.Text = "TP"
            tp.BackgroundColor3 = Color3.fromRGB(0, 80, 0)
            tp.MouseButton1Click:Connect(function() player.Character.HumanoidRootPart.CFrame = p.Character.HumanoidRootPart.CFrame end)

            -- KICK Button
            local kick = Instance.new("TextButton", row)
            kick.Size = UDim2.new(0.35, 0, 0, 30)
            kick.Position = UDim2.new(0.3, 0, 0.4, 0)
            kick.Text = "KICK"
            kick.BackgroundColor3 = Color3.fromRGB(200, 100, 0)
            kick.MouseButton1Click:Connect(function() deepAdmin(p, "KICK") end)

            -- BAN Button
            local ban = Instance.new("TextButton", row)
            ban.Size = UDim2.new(0.35, 0, 0, 30)
            ban.Position = UDim2.new(0.65, 0, 0.4, 0)
            ban.Text = "BAN"
            ban.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
            ban.MouseButton1Click:Connect(function() deepAdmin(p, "BAN") end)
        end
    end
end

-- Hauptbuttons
local function btn(t, f)
    local b = Instance.new("TextButton", container)
    b.Size = UDim2.new(1, 0, 0, 30)
    b.Text = t
    b.BackgroundColor3 = Color3.fromRGB(40,40,40)
    b.TextColor3 = Color3.new(1,1,1)
    b.MouseButton1Click:Connect(f)
end

btn("Fly Toggle", toggleFly)
btn("Emote: Bang", function() 
    local a = Instance.new("Animation") a.AnimationId = "rbxassetid://148840339"
    player.Character.Humanoid:LoadAnimation(a):Play() 
end)
btn("Emote: Suck", function() 
    local a = Instance.new("Animation") a.AnimationId = "rbxassetid://204328711"
    player.Character.Humanoid:LoadAnimation(a):Play() 
end)
btn("Player Admin Menu", function() 
    pFrame.Visible = not pFrame.Visible
    if pFrame.Visible then updateList() end
end)
btn("Close GUI", function() screenGui:Destroy() end)

-- PC Toggle
userInput.InputBegan:Connect(function(i, g)
    if not g and i.KeyCode == Enum.KeyCode.F3 then main.Visible = not main.Visible end
end)

